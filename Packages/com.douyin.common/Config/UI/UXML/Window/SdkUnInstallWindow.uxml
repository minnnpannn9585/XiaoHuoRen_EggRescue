            <ui:Button text="确定" display-tooltip-when-elided="true" name="OkButton" class="size-26 red-button round-coner-6" style="height: 27px; padding-left: 0; padding-right: 0; padding-top: 0; padding-bottom: 0; margin-left: 5px; margin-right: 5px; margin-top: 0; margin-bottom: 0; width: 109px; position: relative; border-left-width: 0; border-right-width: 0; border-top-width: 0; border-bottom-width: 0;" />
