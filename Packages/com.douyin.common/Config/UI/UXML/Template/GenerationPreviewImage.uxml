            <ui:Button display-tooltip-when-elided="true" name="btn-regen" style="background-image: url(&apos;project://database/Packages/com.douyin.common/Config/UI/Icons/img_regen_tbn.png?fileID=2800000&amp;guid=e189aa7026a0b0d42a13fa343186bed6&amp;type=3#img_regen_tbn&apos;); width: 24px; height: 24px; max-width: 24px; max-height: 24px; min-height: 24px; min-width: 24px; margin-left: 8px; margin-right: 0; margin-top: 0; margin-bottom: 0; padding-left: 0; padding-right: 0; padding-top: 0; padding-bottom: 0; background-color: rgba(255, 255, 255, 0); border-left-width: 0; border-right-width: 0; border-top-width: 0; border-bottom-width: 0; display: flex;" />
